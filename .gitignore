# modified Allowlisting gitignore
# Ignore everything
*

!/.dockerignore
!/.gitignore
!/.gitkeep

!LICENSES/*.txt
!VERSION
!Makefile

!README.md

# go
!go.sum
!go.mod
!main.go
!cmd/**.go

# one document directory to consolidate them all
!docs/**/*.md

# track
!asb/**
!nrf/**

# but not these files or (sub)directories
!*/

# explicitly ignore
.venv/
venv/
.env

# ignore experimentation and in-progress development
.exp/**
exp/**

# don't track the ansible inventory here
asb/inventories/
asb/.collections/
asb/.vp

# no pyc
__pycache__/

# no logs
logs/
